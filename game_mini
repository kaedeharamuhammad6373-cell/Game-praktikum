import tkinter as tk
from tkinter import messagebox
import json

SAVE_FILE = "savegame.json"
TILE = 40

# ──────────────────────────────────────────────
#  KARAKTER BASE
# ──────────────────────────────────────────────

class Character:
    def __init__(self, x: int, y: int):
        self.x = x
        self.y = y


# ──────────────────────────────────────────────
#  PLAYER
# ──────────────────────────────────────────────

class Player(Character):
    def __init__(self, x: int, y: int):
        super().__init__(x, y)
        self.lives = 3
        self.score = 0
        self.has_key = False
        self.spawn_x = x   # FIX: simpan posisi spawn
        self.spawn_y = y


# ──────────────────────────────────────────────
#  GUARD  – FOV mengikuti arah gerak
# ──────────────────────────────────────────────

class Guard(Character):
    def __init__(self, x: int, y: int):
        super().__init__(x, y)
        self.dir = 1          # +1 = kanan, -1 = kiri

    def update(self, game: "Game"):
        nx = self.x + self.dir
        if not game.walkable(nx, self.y):
            self.dir *= -1    # balik arah saat kena tembok
        else:
            self.x = nx

    def fov_cells(self) -> list[tuple[int, int]]:
        """Kembalikan sel di depan guard – HANYA sampai sebelum tembok."""
        # FIX: FOV berhenti kalau kena tembok, tidak nembus
        cells = []
        for i in range(1, 4):
            cx = self.x + self.dir * i
            cy = self.y
            cells.append((cx, cy))
        return cells

    def can_see(self, player: Player, game: "Game") -> bool:
        """Cek apakah player ada di FOV guard, dengan ray-cast sederhana."""
        # FIX: cek line-of-sight; berhenti kalau ada tembok di antaranya
        for i in range(1, 4):
            cx = self.x + self.dir * i
            cy = self.y
            # kalau sel ini tembok, FOV terblokir di sini
            if not game.walkable(cx, cy):
                break
            if player.x == cx and player.y == cy:
                return True
        return False


# ──────────────────────────────────────────────
#  DOG – mengejar player jika dekat
# ──────────────────────────────────────────────

class Dog(Character):
    CHASE_RADIUS = 3   # dikurangin dari 4 biar lebih fair

    def update(self, game: "Game"):
        p = game.player
        dist = abs(p.x - self.x) + abs(p.y - self.y)

        if dist > self.CHASE_RADIUS:
            return  # terlalu jauh, diam

        dx = 0
        dy = 0
        if abs(p.x - self.x) > abs(p.y - self.y):
            dx = 1 if p.x > self.x else -1
        else:
            dy = 1 if p.y > self.y else -1

        nx, ny = self.x + dx, self.y + dy
        if game.walkable(nx, ny):
            new_dist = abs(p.x - nx) + abs(p.y - ny)
            if new_dist < dist:
                self.x, self.y = nx, ny


