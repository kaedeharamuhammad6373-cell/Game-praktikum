# Mengatasi error di MacBook (karena winsound khusus untuk Windows)
try:
    import winsound
    HAS_WINSOUND = True
except ImportError:
    HAS_WINSOUND = False

def play_beep(sound_type: str):
    def sound_task():
        try:
            if platform.system() == "Darwin":
                if sound_type == "loot":
                    os.system("afplay /System/Library/Sounds/Pop.aiff")
                elif sound_type == "key":
                    os.system("afplay /System/Library/Sounds/Tink.aiff")
                elif sound_type == "door":
                    os.system("afplay /System/Library/Sounds/Glass.aiff")
                elif sound_type == "caught":
                    os.system("afplay /System/Library/Sounds/Basso.aiff")
                elif sound_type == "win":
                    os.system("afplay /System/Library/Sounds/Hero.aiff")
            elif HAS_WINSOUND:
                if sound_type == "loot":
                    winsound.Beep(1500, 80)
                elif sound_type == "key":
                    winsound.Beep(800, 100)
                    winsound.Beep(1200, 150)
                elif sound_type == "door":
                    winsound.Beep(1000, 100)
                    winsound.Beep(1500, 200)
                elif sound_type == "caught":
                    winsound.Beep(400, 200)
                    winsound.Beep(300, 300)
                elif sound_type == "win":
                    for f in [523, 659, 784, 1046]:
                        winsound.Beep(f, 150)
        except:
            pass
    threading.Thread(target=sound_task, daemon=True).start()

def play_bgm():
    # Cari bgm.wav di folder yang sama dengan script ini
    bgm_file = os.path.join(os.path.dirname(os.path.abspath(__file__)), "bgm.wav")
    if not os.path.exists(bgm_file):
        print(f"[BGM] File tidak ditemukan: {bgm_file}")
        return
    try:
        if platform.system() == "Darwin":
            def mac_bgm():
                while True:
                    os.system(f"afplay \"{bgm_file}\"")
            threading.Thread(target=mac_bgm, daemon=True).start()
        elif HAS_WINSOUND:
            winsound.PlaySound(bgm_file, winsound.SND_FILENAME | winsound.SND_ASYNC | winsound.SND_LOOP)
    except Exception as e:
        print(f"[BGM] Gagal memutarkan: {e}")

